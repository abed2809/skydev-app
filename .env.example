# ── Cloudinary ──────────────────────────────────────────────────────────────
# 1. Sign up at https://cloudinary.com (free tier works)
# 2. Your cloud name is in the Cloudinary dashboard
# 3. Create an "Upload Preset" under Settings → Upload → Add upload preset
#    Set it to "Unsigned" so the frontend can upload without a server
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ── EmailJS ──────────────────────────────────────────────────────────────────
# 1. Sign up at https://www.emailjs.com (free: 200 emails/month)
# 2. Create a service (e.g. Gmail) → get the Service ID
# 3. Create an email template → get the Template ID
# 4. Go to Account → API Keys → copy your Public Key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key
